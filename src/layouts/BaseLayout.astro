---
import '../styles/global.css';
import StarsCanvas from '../components/StarsCanvas.astro';

const {
  title = 'KUNLING · Intelligent Numerical Geoscience',
  description = 'KUNLING develops AI-native methods for ocean geology, geodynamic simulation, Earth system reconstruction, and scientific visualization.',
  bodyClass = '',
} = Astro.props;

const currentPath = Astro.url.pathname;
const socialImage = new URL('/og.png', Astro.site ?? Astro.url.origin).toString();
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();
const navigation = [
  { label: 'Research', href: '/research/', match: '/research' },
  { label: 'Our Team', href: '/our-team/', match: '/our-team' },
  { label: 'Open Source', href: '/open-source/', match: '/open-source' },
  { label: 'Contact', href: '/contact/', match: '/contact' },
];
const hostLabPartners = [
  { name: 'California Institute of Technology', href: 'https://www.caltech.edu/' },
  { name: 'Scripps Institution of Oceanography', href: 'https://scripps.ucsd.edu/' },
  { name: 'Texas A&M University', href: 'https://www.tamu.edu/' },
  { name: 'Woods Hole Oceanographic Institution', href: 'https://www.whoi.edu/' },
  { name: 'IFREMER', href: 'https://www.ifremer.fr/en' },
  { name: 'GEOMAR Helmholtz Centre for Ocean Research Kiel', href: 'https://www.geomar.de/en' },
  { name: 'First Institute of Oceanography', href: 'https://www.fio.org.cn/' },
  { name: 'JAMSTEC', href: 'https://www.jamstec.go.jp/e/' },
  { name: 'Second Institute of Oceanography', href: 'https://www.sio.org.cn/' },
  { name: 'State Key Laboratory of Marine Environmental Science', href: 'https://mel.xmu.edu.cn/' },
  { name: 'Guangzhou Marine Geological Survey', href: 'https://www.gmgs.cgs.gov.cn/' },
  { name: 'EarthByte Group', href: 'https://www.earthbyte.org/' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#020306" />
    <meta name="color-scheme" content="dark" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="preload" href="/assets/fonts/faire-octave.woff2" as="font" type="font/woff2" crossorigin />
    {currentPath === '/' && <link rel="preload" href="/assets/earth/blue-marble.jpg" as="image" />}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="KUNLING" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:url" content={Astro.url.toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <link rel="icon" type="image/png" href="/assets/brand/kunling-logo.png" />
    <title>{title}</title>
  </head>
  <body class={bodyClass}>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <StarsCanvas />
    <div class="page-noise" aria-hidden="true"></div>

    <header class="site-header" data-site-header>
      <nav class="site-nav" aria-label="Main navigation">
        <a class="brand" href="/" aria-label="KUNLING home">
          <img src="/assets/brand/kunling-logo.png" alt="" />
          <span>KUNLING</span>
        </a>

        <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="primary-navigation" data-menu-toggle>
          <span></span><span></span>
          <span class="sr-only">Toggle navigation</span>
        </button>

        <div class="nav-links" id="primary-navigation" data-nav-links>
          {navigation.map((item) => (
            <a
              href={item.href}
              class:list={[{ active: currentPath.startsWith(item.match) }]}
              aria-current={currentPath.startsWith(item.match) ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))}
          <a class="nav-github" href="https://github.com/Kunling-AI" target="_blank" rel="noreferrer">GitHub ↗</a>
          <span class="location-chip" aria-label="KUNLING is based in Qingdao, China"><i></i>Qingdao · CN</span>
        </div>
      </nav>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand-block">
          <a class="footer-brand" href="/">
            <img src="/assets/brand/kunling-logo.png" alt="" />
            <span>KUNLING</span>
          </a>
          <p>Knowledge-augmented Universal Neural Learning for Intelligent Numerical Geoscience.</p>
          <p class="footer-affiliation">Hosted at the <a href="https://geolab.ouc.edu.cn/main.htm" target="_blank" rel="noreferrer">Key Lab of Submarine Geosciences and Prospecting Techniques, MOE</a>, Ocean University of China.</p>
        </div>
        <div class="footer-links">
          {navigation.map((item) => <a href={item.href}>{item.label}</a>)}
          <a href="https://github.com/Kunling-AI" target="_blank" rel="noreferrer">GitHub ↗</a>
        </div>
        <div class="footer-meta">
          <a href="mailto:liuze@ouc.edu.cn">liuze@ouc.edu.cn</a>
          <span>238 Songling Road, Laoshan District</span>
          <span>Qingdao 266100, Shandong, P.R. China</span>
          <span>© 2026 KUNLING</span>
        </div>
      </div>
      <div class="footer-network">
        <div class="footer-network-heading">
          <span>Host laboratory network</span>
          <a href="https://geolab.ouc.edu.cn/gljg_14316/list.htm" target="_blank" rel="noreferrer">View official network ↗</a>
        </div>
        <div class="footer-partners" aria-label="Cooperative institutions listed by the host laboratory">
          {hostLabPartners.map((partner) => (
            <a href={partner.href} target="_blank" rel="noreferrer">{partner.name}<span aria-hidden="true">↗</span></a>
          ))}
        </div>
      </div>
      <div class="footer-credit">
        <span>SpaceLab template by <a href="https://github.com/choucisan/SpaceLab" target="_blank" rel="noreferrer">choucisan</a>.</span>
        <span>Earth texture: NASA/GSFC Scientific Visualization Studio.</span>
      </div>
    </footer>

    <script>
      const header = document.querySelector<HTMLElement>('[data-site-header]');
      const menuToggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
      const navLinks = document.querySelector<HTMLElement>('[data-nav-links]');

      const updateHeader = () => header?.classList.toggle('is-scrolled', window.scrollY > 30);
      updateHeader();
      window.addEventListener('scroll', updateHeader, { passive: true });

      const setMenuState = (open: boolean) => {
        menuToggle?.setAttribute('aria-expanded', String(open));
        navLinks?.classList.toggle('is-open', open);
        document.body.classList.toggle('menu-open', open);
      };

      menuToggle?.addEventListener('click', () => {
        const open = menuToggle.getAttribute('aria-expanded') === 'true';
        setMenuState(!open);
      });

      navLinks?.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => setMenuState(false));
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          setMenuState(false);
          menuToggle?.focus();
        }
      });

      window.addEventListener('resize', () => {
        if (window.innerWidth > 1100) setMenuState(false);
      }, { passive: true });

      const revealItems = document.querySelectorAll<HTMLElement>('[data-reveal]');
      if ('IntersectionObserver' in window && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.documentElement.classList.add('reveal-ready');
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -36px' });
        revealItems.forEach((item) => observer.observe(item));
      }
    </script>
  </body>
</html>
