---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact · KUNLING" description="Contact KUNLING at Ocean University of China.">
  <section class="contact-hero">
    <div class="container contact-center" data-reveal>
      <span class="section-kicker">Connect</span>
      <h1>Contact Us</h1>
      <p>For research conversations, scientific collaboration, and open-source work, reach out through the channels below.</p>
      <div class="contact-orbits">
        <a href="mailto:liuze@ouc.edu.cn" aria-label="Email Ze Liu">
          <img src="/assets/icons/gmail.svg" alt="" />
          <span>Email</span>
        </a>
        <a href="https://github.com/Kunling-AI" target="_blank" rel="noreferrer" aria-label="KUNLING on GitHub">
          <img src="/assets/icons/github.svg" alt="" />
          <span>GitHub</span>
        </a>
        <a href="https://cmg.ouc.edu.cn/2024/1227/c30164a492019/page.htm" target="_blank" rel="noreferrer" aria-label="Official university profile">
          <img src="/assets/brand/kunling-logo.png" alt="" />
          <span>OUC</span>
        </a>
      </div>
      <div class="contact-address">
        <span>PRINCIPAL CONTACT</span>
        <strong>Ze Liu · Associate Professor</strong>
        <a href="mailto:liuze@ouc.edu.cn">liuze@ouc.edu.cn</a>
        <p>Ocean University of China · Qingdao, China</p>
      </div>
    </div>
  </section>
</BaseLayout>
