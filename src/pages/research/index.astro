---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { researchProjects } from '../../data/research';
---

<BaseLayout title="Research · KUNLING" description="KUNLING research connects scientific agents, geodynamic simulation, marine geological data, physics-guided learning, and visualization.">
  <section class="subpage-hero research-page-hero">
    <div class="container" data-reveal>
      <span class="section-kicker">Research</span>
      <h1>Six directions. One connected Earth.</h1>
      <p>Our research connects scientific agents, geodynamic simulation, global marine geological data, physics-guided learning, and visualization. Across these directions, we study how AI can participate in the complete scientific workflow while preserving physical reasoning, traceable evidence, and reproducibility.</p>
    </div>
  </section>

  <section class="research-list section-shell">
    <div class="container">
      {researchProjects.map((project) => (
        <article class="research-detail" id={`project-${project.index}`} data-reveal>
          <div class="research-detail-index">
            <span>{project.index}</span>
            <small>{project.shortName}</small>
          </div>
          <div class="research-detail-copy">
            <h2>{project.name}</h2>
            <p class="research-detail-subtitle">{project.subtitle}</p>
            <p>{project.overview}</p>
            <blockquote>{project.question}</blockquote>
            <div class="research-tags">
              {project.methods.map((method) => <span>{method}</span>)}
            </div>
            {project.githubUrl && (
              <a class="inline-link research-detail-link" href={project.githubUrl} target="_blank" rel="noreferrer">View project on GitHub ↗</a>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
