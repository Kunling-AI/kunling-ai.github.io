---

<section class="earth-hero" data-earth-stage aria-labelledby="hero-title">
  <div class="earth-canvas-wrap" aria-hidden="true">
    <canvas class="earth-canvas" data-earth-canvas></canvas>
    <div class="earth-css-fallback" data-earth-fallback>
      <span></span>
    </div>
    <div class="earth-aura"></div>
  </div>

  <div class="earth-hero-copy">
    <p class="hero-kicker">KUNLING · Intelligent Numerical Geoscience</p>
    <h1 id="hero-title">AI for a connected <span>Earth.</span></h1>
    <p class="hero-subtitle">We connect intelligent agents, physical simulation, global marine data, and scientific visualization to study our planet across space and deep time.</p>
    <div class="hero-actions">
      <a class="button hero-primary-button" href="/research/">Explore our research <span aria-hidden="true">↗</span></a>
      <a class="button hero-secondary-button" href="/our-team/">Meet the team</a>
    </div>
  </div>

  <div class="hero-facts" aria-label="KUNLING at a glance">
    <div><strong>06</strong><span>Research directions</span></div>
    <div><strong>AI × Physics</strong><span>One connected workflow</span></div>
    <div><strong>OUC</strong><span>Qingdao · China</span></div>
  </div>

  <div class="earth-coordinate" aria-hidden="true">
    <span class="coordinate-pulse"></span>
    QINGDAO · 36.0671° N · 120.3826° E
  </div>

  <a class="scroll-cue" href="#mission">
    <span>Scroll to explore</span>
    <span aria-hidden="true">↓</span>
  </a>
</section>

<script>
  const stage = document.querySelector<HTMLElement>('[data-earth-stage]');
  const canvas = stage?.querySelector<HTMLCanvasElement>('[data-earth-canvas]');
  const fallback = stage?.querySelector<HTMLElement>('[data-earth-fallback]');

  const initializeEarth = async () => {
    if (!stage || !canvas) return;

    try {
      const three = await import('../lib/three-earth');
      const {
        ACESFilmicToneMapping,
        AdditiveBlending,
        BackSide,
        DirectionalLight,
        Group,
        HemisphereLight,
        Mesh,
        MeshBasicMaterial,
        MeshStandardMaterial,
        PerspectiveCamera,
        Scene,
        ShaderMaterial,
        SphereGeometry,
        SRGBColorSpace,
        TextureLoader,
        TorusGeometry,
        WebGLRenderer,
      } = three;
      const { OrbitControls } = three;

      const renderer = new WebGLRenderer({
        canvas,
        alpha: true,
        antialias: true,
        powerPreference: 'high-performance',
      });
      renderer.setClearColor(0x000000, 0);
      renderer.outputColorSpace = SRGBColorSpace;
      renderer.toneMapping = ACESFilmicToneMapping;
      renderer.toneMappingExposure = 1.08;

      const scene = new Scene();
      const camera = new PerspectiveCamera(42, 1, 0.1, 100);
      camera.position.set(0, 0.15, 6.3);

      const globe = new Group();
      globe.rotation.z = -0.13;
      scene.add(globe);

      const loader = new TextureLoader();
      const earthTexture = loader.load('/assets/earth/blue-marble.jpg', () => {
        fallback?.setAttribute('hidden', '');
        stage.classList.add('earth-ready');
      });
      earthTexture.colorSpace = SRGBColorSpace;
      earthTexture.anisotropy = Math.min(8, renderer.capabilities.getMaxAnisotropy());

      const earth = new Mesh(
        new SphereGeometry(2.18, 96, 64),
        new MeshStandardMaterial({
          map: earthTexture,
          roughness: 0.84,
          metalness: 0.02,
        }),
      );
      earth.rotation.y = -1.82;
      globe.add(earth);

      const atmosphere = new Mesh(
        new SphereGeometry(2.27, 72, 48),
        new ShaderMaterial({
          transparent: true,
          side: BackSide,
          blending: AdditiveBlending,
          depthWrite: false,
          vertexShader: `
            varying vec3 vNormal;
            void main() {
              vNormal = normalize(normalMatrix * normal);
              gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
            }
          `,
          fragmentShader: `
            varying vec3 vNormal;
            void main() {
              float intensity = pow(0.64 - dot(vNormal, vec3(0.0, 0.0, 1.0)), 3.4);
              gl_FragColor = vec4(0.42, 0.69, 1.0, max(0.0, intensity) * 0.8);
            }
          `,
        }),
      );
      globe.add(atmosphere);

      const wire = new Mesh(
        new SphereGeometry(2.195, 48, 32),
        new MeshBasicMaterial({
          color: 0x9bc4ff,
          wireframe: true,
          transparent: true,
          opacity: 0.027,
          depthWrite: false,
        }),
      );
      wire.rotation.y = earth.rotation.y;
      globe.add(wire);

      const orbit = new Mesh(
        new TorusGeometry(2.78, 0.006, 8, 220),
        new MeshBasicMaterial({ color: 0xe7b3d3, transparent: true, opacity: 0.36 }),
      );
      orbit.rotation.x = Math.PI / 2.7;
      orbit.rotation.y = -0.35;
      globe.add(orbit);

      const ambient = new HemisphereLight(0xb9d9ff, 0x091326, 1.15);
      scene.add(ambient);
      const keyLight = new DirectionalLight(0xffffff, 3.1);
      keyLight.position.set(-4.8, 3.3, 5.4);
      scene.add(keyLight);
      const rimLight = new DirectionalLight(0xa95f9d, 1.1);
      rimLight.position.set(4.5, -1.2, -3.5);
      scene.add(rimLight);

      const controls = new OrbitControls(camera, canvas);
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      controls.enableDamping = true;
      controls.dampingFactor = 0.045;
      controls.enablePan = false;
      controls.enableZoom = false;
      controls.rotateSpeed = 0.34;
      controls.autoRotate = !prefersReducedMotion;
      controls.autoRotateSpeed = 0.28;

      const resize = () => {
        const width = stage.clientWidth;
        const height = stage.clientHeight;
        const pixelRatio = Math.min(window.devicePixelRatio || 1, 1.6);
        renderer.setPixelRatio(pixelRatio);
        renderer.setSize(width, height, false);
        camera.aspect = width / Math.max(height, 1);
        camera.updateProjectionMatrix();
        camera.position.z = width < 720 ? 7.25 : 6.3;
      };

      let running = true;
      const observer = new IntersectionObserver(([entry]) => {
        running = entry.isIntersecting;
      }, { threshold: 0.02 });
      observer.observe(stage);

      const animationStart = performance.now();
      const render = () => {
        if (!prefersReducedMotion) requestAnimationFrame(render);
        if (!running || document.hidden) return;
        const elapsed = prefersReducedMotion ? 0 : (performance.now() - animationStart) / 1000;
        orbit.rotation.z = elapsed * 0.045;
        wire.rotation.y = earth.rotation.y - elapsed * 0.008;
        controls.update();
        renderer.render(scene, camera);
      };

      const resizeObserver = new ResizeObserver(resize);
      resizeObserver.observe(stage);
      resize();
      render();

      if (prefersReducedMotion) {
        controls.enableDamping = false;
        controls.addEventListener('change', () => renderer.render(scene, camera));
      }
    } catch {
      stage.classList.add('earth-fallback-only');
    }
  };

  if (stage && canvas) {
    const idleWindow = window as Window & {
      requestIdleCallback?: (callback: IdleRequestCallback, options?: IdleRequestOptions) => number;
    };
    if (idleWindow.requestIdleCallback) {
      idleWindow.requestIdleCallback(() => void initializeEarth(), { timeout: 900 });
    } else {
      setTimeout(() => void initializeEarth(), 120);
    }
  }
</script>
